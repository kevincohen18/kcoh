# Public, build-time env for production builds (Cloudflare Pages Git build reads this).
# The Turnstile SITE key is public by design — it ships in the client bundle.
# Secret keys (RESEND_API_KEY, TURNSTILE_SECRET_KEY) are NOT here — they are set as
# encrypted Pages secrets via `wrangler pages secret put`.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADuMM4MbdeDSL10e
